<script>
	$(document).ready(function() {
		$(".sub_menu").hide();
		$(".menu_li").click(function() {
			$(".sub_menu").slideUp();
			var subMenu = $(this).children('ul');
			if (subMenu.is(':hidden')) {
			subMenu.slideDown();
		} else {
			subMenu.slideUp();
		}
});
	$('#dashboard').hover(
	function() {
		$(this).stop().animate({left:'0'}, 400);
		$('#arrows').stop().animate({backgroundPositionY:"0px"});
	},
		function() {
		$(this).stop().animate({left:'-60px'}, 400);
			$('#arrows').stop().animate({backgroundPositionY:"-20px"});
		}
	);
	});
	</script>
